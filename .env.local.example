# ── Supabase ──────────────────────────────────────────────────────────────────
# https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Optional: service role key for admin operations (never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── EODHD ─────────────────────────────────────────────────────────────────────
# Required for live asset prices (BTC, ASX ETFs, US stocks, etc.)
# Free tier gives end-of-day data; paid tier gives real-time.
# https://eodhd.com/cp/dashboard
EODHD_API_KEY=<your-eodhd-api-key>

# ── App defaults ──────────────────────────────────────────────────────────────
# Used as fallback AUD/USD rate if not set in household_settings
DEFAULT_AUD_USD_RATE=0.65
