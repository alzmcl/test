# Supabase — copy to .env.local and fill in your project values
# https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Optional: CoinGecko Pro API key for higher rate limits
# Leave blank to use the free public endpoint
COINGECKO_API_KEY=
